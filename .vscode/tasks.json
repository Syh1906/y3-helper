// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "compile",
            "problemMatcher": "$ts-webpack",
            "isBackground": false,
            "group": {
                "kind": "build",
                "isDefault": true
            },
        },
        {
            "type": "shell",
            "label": "🍟生成dts",
            "command": "npx dts-bundle-generator --config dts-bundle-generator.config.json; node dts-post.js",
            
        },
        {
            "type": "shell",
            "label": "🆎提取文本",
            "command": [
                "npx @vscode/l10n-dev export -o ./dist ./src",
            ],
        },
        {
            "type": "shell",
            "label": "📦编译VSIX",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "$pkg = Get-Content -LiteralPath 'package.json' -Raw | ConvertFrom-Json; New-Item -ItemType Directory -Force -Path 'dist/vsix' | Out-Null; npx --yes @vscode/vsce package --out \"dist/vsix/$($pkg.name)-$($pkg.version).vsix\""
            ],
            "group": "build",
            "problemMatcher": "$ts-webpack",
        }
    ]
}
